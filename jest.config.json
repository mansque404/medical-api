{
  "preset": "ts-jest",
  "testEnvironment": "node",
  "roots": ["<rootDir>/src"],
  "testMatch": ["**/__tests__/**/*.ts", "**/?(*.)+(spec|test).ts"],
  "transform": {
    "^.+\\.ts$": "ts-jest"
  },
  "collectCoverageFrom": ["src/**/*.ts", "!src/**/*.d.ts", "!src/**/*.interface.ts", "!src/**/mocks/**"],
  "coverageDirectory": "coverage",
  "coverageReporters": ["text", "lcov", "html"]
}
